# ===================================================================
# Unity .gitignore
# Project: Digital Cryptid (LogicHunter)
# ===================================================================

# -----------------------------------------------
# AI Agent Rules & Specs (Local Only)
# -----------------------------------------------
@AGENT_RULES.md
@DEVELOPMENT_SPEC.md
@CONSOLE_ERRORS.md

# -----------------------------------------------
# Steam App ID (replace 480 with real App ID before shipping)
# -----------------------------------------------
steam_appid.txt

# -----------------------------------------------
# DOTween Settings (machine-specific, regenerated by Setup DOTween)
# -----------------------------------------------
Assets/Resources/DOTweenSettings.asset
Assets/Resources/DOTweenSettings.asset.meta

# -----------------------------------------------
# Unused Systems (kept locally for reference)
# -----------------------------------------------
Assets/_Project/Scripts/Systems/Gameplay/SimpleAIPlayer.cs
Assets/_Project/Scripts/Systems/Gameplay/SimpleAIPlayer.cs.meta

# -----------------------------------------------
# Unity Generated
# -----------------------------------------------
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# -----------------------------------------------
# Memory Profiler Snapshots
# -----------------------------------------------
MemoryCaptures/

# -----------------------------------------------
# Recordings (Unity Recorder)
# -----------------------------------------------
[Rr]ecordings/

# -----------------------------------------------
# Asset meta data should only be ignored when
# having a hierarchical text serialization mode
# -----------------------------------------------
# *.pidb.meta
# *.pdb.meta
# *.mdb.meta

# -----------------------------------------------
# Visual Studio / Rider / VS Code
# -----------------------------------------------
ExportedObj/
.vs/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
.idea/

# -----------------------------------------------
# Gradle (Android Build)
# -----------------------------------------------
*.apk
*.aab
*.unitypackage
*.gradle

# -----------------------------------------------
# Crashlytics
# -----------------------------------------------
crashlytics-build.properties
sysinfo.txt

# -----------------------------------------------
# OS Generated
# -----------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -----------------------------------------------
# Plastic SCM (Unity Version Control)
# -----------------------------------------------
ignore.conf
*.private.0
*.private

# -----------------------------------------------
# Visual Studio Code
# -----------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# -----------------------------------------------
# TextMeshPro (auto-generated; re-importable)
# -----------------------------------------------
Assets/TextMesh Pro/

# -----------------------------------------------
# Burst AOT
# -----------------------------------------------
Assets/StreamingAssets/aa.meta
Assets/StreamingAssets/aa/

# -----------------------------------------------
# NuGet (if using NuGetForUnity)
